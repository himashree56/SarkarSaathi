# AWS Configuration for Nova/Bedrock Chatbot
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here

# Nova Model (budget options):
# amazon.nova-micro-v1:0  — cheapest, fastest (recommended for dev)
# amazon.nova-lite-v1:0   — balanced
# amazon.nova-pro-v1:0    — most capable
NOVA_MODEL_ID=amazon.nova-micro-v1:0

# Token limit per response (lower = cheaper)
MAX_TOKENS=512
